@baseUrl = http://localhost:8080
@tenantId = 11111111-1111-1111-1111-111111111111
@lojaId = 22222222-2222-2222-2222-222222222222
@userId = 44444444-4444-4444-4444-444444444444
@adminId = 33333333-3333-3333-3333-333333333333
@produtoId = 55555555-5555-5555-5555-555555555551

### Health
GET {{baseUrl}}/health

### Métricas Prometheus
GET {{baseUrl}}/metrics

### Onboarding novo tenant (público)
POST {{baseUrl}}/api/v1/public/onboarding
Content-Type: application/json

{
  "nomeFantasia": "Nova Loja",
  "razaoSocial": "Nova Loja LTDA",
  "cnpj": "98765432000100",
  "adminNome": "João Admin",
  "adminEmail": "joao@novaloja.com"
}

### Dashboard resumo
GET {{baseUrl}}/api/v1/dashboard/resumo?lojaId={{lojaId}}
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}

### Listar produtos
GET {{baseUrl}}/api/v1/produtos?page=0&size=20
X-Tenant-Id: {{tenantId}}

### Buscar produtos
GET {{baseUrl}}/api/v1/produtos/busca?termo=coca
X-Tenant-Id: {{tenantId}}

### Criar produto
POST {{baseUrl}}/api/v1/produtos
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "sku": "PROD-001",
  "codigoBarras": "7891000100103",
  "nome": "Refrigerante 2L",
  "descricao": "Refrigerante cola 2 litros",
  "precoVenda": 9.90
}

### Listar clientes
GET {{baseUrl}}/api/v1/clientes?page=0&size=20
X-Tenant-Id: {{tenantId}}

### Criar cliente
POST {{baseUrl}}/api/v1/clientes
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "nome": "Maria Cliente",
  "cpfCnpj": "12345678901",
  "email": "maria@email.com",
  "telefone": "11999999999"
}

### Listar estoques
GET {{baseUrl}}/api/v1/estoques?lojaId={{lojaId}}
X-Tenant-Id: {{tenantId}}

### Ajuste de estoque
POST {{baseUrl}}/api/v1/estoques/ajustes
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
Content-Type: application/json

{
  "lojaId": "{{lojaId}}",
  "produtoId": "{{produtoId}}",
  "quantidade": 50,
  "motivo": "Estoque inicial"
}

### Abrir caixa
POST {{baseUrl}}/api/v1/caixas/abrir
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
Content-Type: application/json

{
  "lojaId": "{{lojaId}}",
  "valorAbertura": 100.00
}

### Caixa aberto
GET {{baseUrl}}/api/v1/caixas/aberto?lojaId={{lojaId}}&operadorId={{userId}}
X-Tenant-Id: {{tenantId}}

### Criar venda
POST {{baseUrl}}/api/v1/vendas
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
Content-Type: application/json

{
  "lojaId": "{{lojaId}}"
}

### Adicionar item (substituir vendaId)
POST {{baseUrl}}/api/v1/vendas/PREENCHER_VENDA_ID/itens
X-Tenant-Id: {{tenantId}}
Content-Type: application/json

{
  "produtoId": "{{produtoId}}",
  "quantidade": 2,
  "desconto": 0
}

### Finalizar venda
POST {{baseUrl}}/api/v1/vendas/PREENCHER_VENDA_ID/finalizar
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}

### Listar vendas
GET {{baseUrl}}/api/v1/vendas?lojaId={{lojaId}}
X-Tenant-Id: {{tenantId}}

### Contas a receber
GET {{baseUrl}}/api/v1/financeiro/contas-receber?lojaId={{lojaId}}
X-Tenant-Id: {{tenantId}}

### Marcar conta como paga
PATCH {{baseUrl}}/api/v1/financeiro/contas-receber/PREENCHER_CONTA_ID/pagar
X-Tenant-Id: {{tenantId}}
X-User-Id: {{adminId}}

### Listar usuários
GET {{baseUrl}}/api/v1/usuarios
X-Tenant-Id: {{tenantId}}
X-User-Id: {{adminId}}

### Configurações da loja
GET {{baseUrl}}/api/v1/configuracoes?lojaId={{lojaId}}
X-Tenant-Id: {{tenantId}}

### Fechar caixa (substituir caixaId)
POST {{baseUrl}}/api/v1/caixas/PREENCHER_CAIXA_ID/fechar
X-Tenant-Id: {{tenantId}}
X-User-Id: {{userId}}
Content-Type: application/json

{
  "valorFechamentoInformado": 119.80
}
